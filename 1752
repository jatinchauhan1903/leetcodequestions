class Solution {
    public boolean check(int[] arr) {
        int count=0,n=arr.length;
        for(int i=0;i<arr.length;i++)
        {
            if(arr[i]>arr[(i+1)%n])
            {
                count++;
            }
        }
        if(count<=1)
        {
            return true;
        }
        return false;
    }
}
